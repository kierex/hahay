{
  "version": 2,
  "installCommand": "cd ../.. && npm install -g pnpm && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/api-server build",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production",
    "CORS_ORIGIN": ""
  }
}
